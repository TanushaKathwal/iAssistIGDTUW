<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/navigation_home">

    <!-- Home -->
    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.iassistdatabase.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <!-- Notifications -->
    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.example.iassistdatabase.ui.notifications.NotificationsFragment"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_notifications" />

    <!-- Signup -->
    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.iassistdatabase.ui.signup.SignupFragment"
        android:label="Signup"
        tools:layout="@layout/fragment_signup">

        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/signupFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Forgot Password -->
    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.iassistdatabase.ui.forgotpassword.ForgotPasswordFragment"
        android:label="Forgot Password?"
        tools:layout="@layout/fragment_forgotpassword">

    <action
        android:id="@+id/action_forgotPasswordFragment_to_loginFragment"
        app:destination="@id/loginFragment" />
</fragment>

