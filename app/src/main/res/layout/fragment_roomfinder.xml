<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@color/green">

    <!-- Title Bar (Top Fixed) -->
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="3dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:contentDescription="iglogo"
            android:src="@drawable/roomfinder_logo" />

        <TextView
            android:id="@+id/textview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:text="Room Finder"
            android:textColor="@android:color/white"
            android:textSize="30sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Scrollable Content Area -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="100dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Date Picker + Spinner + Legend -->
            <LinearLayout
                android:id="@+id/layoutTop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/datePickerEditText"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:background="@android:drawable/edit_text"
                        android:drawableEnd="@android:drawable/ic_menu_today"
                        android:focusable="false"
                        android:hint="Select Date"
                        android:padding="12dp"
                        android:textSize="18sp" />

                    <Spinner
                        android:id="@+id/spinnerTimeSlot"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1" />
                </LinearLayout>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/cell01"
                        style="@style/RoomVacant"
                        android:layout_width="110dp"
                        android:layout_height="50dp"
                        android:layout_margin="10dp"
                        android:padding="12dp"
                        android:text="Vacant" />

                    <TextView
                        android:id="@+id/cell02"
                        style="@style/RoomOccupied"
                        android:layout_width="110dp"
                        android:layout_height="50dp"
                        android:layout_margin="10dp"
                        android:padding="12dp"
                        android:text="Occupied" />
                </LinearLayout>
            </LinearLayout>

            <!-- Section Label -->
            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="16dp"
                android:text="IT"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layoutTop" />

            <!-- Grid Layout -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/gridLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:paddingBottom="50dp"
                app:columnCount="3"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/textView2"
                app:useDefaultMargins="false">

                <!-- Room Cells -->
                <TextView
                    android:id="@+id/cell1"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="104" />

                <TextView
                    android:id="@+id/cell2"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 113" />

                <TextView
                    android:id="@+id/cell3"
                    style="@style/RoomVacant"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="205" />

                <TextView
                    android:id="@+id/cell4"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 209" />

                <TextView
                    android:id="@+id/cell5"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 210" />

                <TextView
                    android:id="@+id/cell6"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="211" />

                <TextView
                    android:id="@+id/cell7"
                    style="@style/RoomVacant"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="213" />

                <TextView
                    android:id="@+id/cell8"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 301" />

                <TextView
                    android:id="@+id/cell9"
                    style="@style/RoomVacant"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="305" />

                <TextView
                    android:id="@+id/cell10"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="309" />

                <TextView
                    android:id="@+id/cell11"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 310" />

                <TextView
                    android:id="@+id/cell12"
                    style="@style/RoomVacant"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="311" />

                <TextView
                    android:id="@+id/cell13"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="312" />

                <TextView
                    android:id="@+id/cell14"
                    style="@style/RoomVacant"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 313" />

                <TextView
                    android:id="@+id/cell15"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="L 401" />

                <TextView
                    android:id="@+id/cell16"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="405" />

                <TextView
                    android:id="@+id/cell17"
                    style="@style/RoomVacant"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="409" />

                <TextView
                    android:id="@+id/cell18"
                    style="@style/RoomOccupied"
                    android:layout_width="90dp"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:padding="12dp"
                    android:text="410" />

            </androidx.gridlayout.widget.GridLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
