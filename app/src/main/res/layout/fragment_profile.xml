<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/green"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="3dp">

            <ImageView
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:contentDescription="Logo"
                android:src="@drawable/profile_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:text="Profile"
                android:textColor="@android:color/white"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Profile Picture with Edit Icon -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImageView"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center|center_horizontal"
                android:foregroundGravity="clip_horizontal"
                android:padding="3dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_defaultprofile"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/green"
                app:strokeWidth="3dp" />


            <ImageView
                android:id="@+id/editProfileImage"
                android:layout_width="37dp"
                android:layout_height="40dp"
                android:layout_alignEnd="@id/profileImageView"
                android:layout_alignBottom="@id/profileImageView"
                android:layout_margin="0dp"
                android:background="@drawable/circle_smallbackground"
                android:padding="5dp"
                android:src="@drawable/ic_edit" />
        </RelativeLayout>

        <!-- Name -->
        <TextView
            android:id="@+id/profileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Name"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Email -->
        <TextView
            android:id="@+id/profileEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="Email"
            android:textSize="18sp" />

        <Button
            android:id="@+id/removeProfileImageButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="clip_horizontal|center"
            android:layout_marginTop="60dp"
            android:text="Remove Photo"
            android:textSize="14sp" />


        <!-- Sign Out Button -->
        <Button
            android:id="@+id/signOutButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="40dp"
            android:backgroundTint="@color/green"
            android:padding="10dp"
            android:text="Sign Out"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
